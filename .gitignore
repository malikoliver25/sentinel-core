# =============================================================================
# sentinel-core — .gitignore
# Python / FastAPI / LangChain project
# =============================================================================

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.env.bak

# ---------------------------------------------------------------------------
# Environment & secrets — NEVER commit
# ---------------------------------------------------------------------------
.env
.env.*
*.pem
*.key
secrets/

# ---------------------------------------------------------------------------
# Python bytecode & cache
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ---------------------------------------------------------------------------
# Distribution / packaging
# ---------------------------------------------------------------------------
*.egg
*.egg-info/
dist/
build/
wheels/
sdist/
.eggs/
MANIFEST

# ---------------------------------------------------------------------------
# Testing & coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/

# ---------------------------------------------------------------------------
# Type checkers & linters
# ---------------------------------------------------------------------------
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json

# ---------------------------------------------------------------------------
# IDEs & editors
# ---------------------------------------------------------------------------
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# macOS
# ---------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride

# ---------------------------------------------------------------------------
# Logs & local data
# ---------------------------------------------------------------------------
*.log
logs/
*.sqlite
*.db
